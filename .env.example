# Copiá este archivo como ".env" y completá los valores
# El archivo .env NUNCA se sube a GitHub (está en .gitignore)

# Token de seguridad para la API — generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=pega_aqui_tu_token_generado

# Puerto local (opcional, por defecto 3000)
# PORT=3000
